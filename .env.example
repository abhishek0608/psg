# Payment: use either .env below OR public/config.json (copy from public/config.example.json)
# Razorpay (frontend)
VITE_RAZORPAY_KEY_ID=rzp_test_xxxx
# VITE_ORDER_API_URL=/api/create-order

# Razorpay (backend – api/create-order.js)
RAZORPAY_KEY_ID=rzp_test_xxxx
RAZORPAY_KEY_SECRET=your_secret

# PostgreSQL (Prisma runtime on Vercel/serverless - use pooler URL)
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-1-ap-northeast-2.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true&connection_limit=1
# PostgreSQL (Prisma migrate - use direct URL)
DIRECT_URL=postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres?sslmode=require

# AWS S3 (product image listing + homepage banner uploads)
# Required for uploads; without these, banner uploads fall back to inline base64.
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-bucket
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
# Optional: top-level folder for product image listing (default: Kiana-product-images)
# AWS_S3_BASE_PREFIX=Kiana-product-images
# Optional: folder for uploaded homepage banners (default: kiana-homepage-banners)
# AWS_S3_HOMEPAGE_PREFIX=kiana-homepage-banners

# Visual search image embeddings (photo-to-photo similarity).
# Kill switch: set IMAGE_VECTOR_SEARCH=off to revert to the old text-based
# visual search instantly (no redeploy of code, vectors stay stored).
# IMAGE_VECTOR_SEARCH=on
# Provider auto-selects: Jina when JINA_API_KEY is set, else AWS Bedrock Titan.
# NOTE: the two providers' vectors are incompatible — switching provider
# invalidates stored vectors and the next seed/save re-embeds automatically.
# JINA_API_KEY=jina_...               (free trial key from jina.ai — no card)
# JINA_IMAGE_EMBED_MODEL=jina-clip-v2
# IMAGE_EMBED_PROVIDER=jina           (force: jina | bedrock)
# BEDROCK_REGION=us-east-1            (default: AWS_REGION, then us-east-1)
# BEDROCK_IMAGE_EMBED_MODEL=amazon.titan-embed-image-v1
# IMAGE_VECTOR_SIMILARITY_THRESHOLD=0.4
# IMAGE_VECTOR_RELAXED_THRESHOLD=0.25

VITE_CHAT_ENDPOINT=chat
# Optional provider override for /api/chat:
# auto | openai | anthropic | huggingface | grok
# CHAT_PROVIDER=auto
# OPENAI_API_KEY=sk-...
# OPENAI_VISION_MODEL=gpt-4o
# GROK_CHAT_MODEL=grok-4-fast-non-reasoning
HF_TOKEN=hf_xxxx
VITE_API_BASE_URL=https://jewellery-website-ashen.vercel.app
